# Copy this file to .env.local and replace every example value below.
# npm run verify:mvp rejects placeholder values and public/service key mixups.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Legacy Supabase anon keys still work, but new publishable keys are preferred.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# Server-only keys for local verification scripts. Never expose service role or
# secret keys in the browser or any NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional server-only AI assistant API. The endpoint should accept an
# OpenAI-compatible chat completions request.
# DEVWIKI_AI_API_URL=http://localhost:8080/v1/chat/completions
# DEVWIKI_AI_API_KEY=your_ai_api_key
# DEVWIKI_AI_MODEL=gpt-4.1-mini
# Set to 1 only if the AI endpoint supports OpenAI JSON mode.
# DEVWIKI_AI_JSON_MODE=1
# DEVWIKI_AI_RATE_LIMIT_PER_10_MINUTES=30

# Optional YouTube Data API key for verified video recommendations.
# Without this key, AI video recommendations fall back to YouTube search links.
# DEVWIKI_YOUTUBE_API_KEY=your_youtube_data_api_key
# DEVWIKI_YOUTUBE_RELEVANCE_LANGUAGE=ko
# DEVWIKI_YOUTUBE_REGION_CODE=KR

# Must be an active members.email value. Use lowercase.
DEVWIKI_E2E_EMAIL=you@example.com
DEVWIKI_E2E_PASSWORD=change-this-password

# Optional verification controls.
# DEVWIKI_E2E_MANAGE_MEMBER=1
# DEVWIKI_E2E_BASE_URL=http://localhost:3000
# DEVWIKI_E2E_PORT=3000
